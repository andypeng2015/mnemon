{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/mnemon/prime.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/mnemon/stop.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/mnemon/user_prompt.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
