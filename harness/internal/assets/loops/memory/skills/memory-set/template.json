{
  "schema_version": 1,
  "capability": "memory",
  "external_id_recipe": "EXTERNAL_ID=\"memory-set-$(printf '%s' \"$CONTENT\" | shasum -a 256 | awk '{print substr($1,1,16)}')\"",
  "notes": [
    "`content`: one concise durable statement",
    "`source`: `user`, `repo`, `agent`, or `command`",
    "`confidence`: `high`, `medium`, or `low`",
    "`tags`: optional short labels",
    "A content hash is acceptable as the external id when the same candidate should dedupe."
  ]
}
